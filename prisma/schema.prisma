generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum StandardExpiryStatus {
  Ready
  ExpiringSoon
  Expired
}

enum ContainerStatus {
  Available
  LowStock
  Expired
  PendingDisposal
}

enum UsageLogType {
  IN
  OUT
  USE
  DISPOSE
}

enum UsageSourceType {
  Chemical
  Standard
  MicrobialStrain
}

enum InventoryItemStatus {
  Available
  LowStock
  Expired
  PendingDisposal
  PendingReview
  InUse
}

enum PreparedStandardLevel {
  RootPrepared
  Intermediate1
  Intermediate2
  Intermediate3
  WorkingPrepared
}

enum PreparedStrainLevel {
  RootPrepared
  Intermediate1
  Intermediate2
  Intermediate3
}

enum CodeEntityType {
  Chemical
  Standard
  MicrobialStrain
  PreparedChemical
  PreparedStandard
  PreparedStrain
}

enum PreparedStandardComponentSourceType {
  Standard
  PreparedStandard
}

enum PreparationType {
  CHEMICAL
  STANDARD
  STRAIN
}

enum PreparationWorkflowStatus {
  Draft
  Prepared
  Checked
  Approved
  Rejected
  Cancelled
}

enum PreparationIngredientRole {
  MAIN
  SOLVENT
  MEDIUM
  ADDITIVE
}

enum InventorySourceType {
  Chemical
  Standard
  PreparedStandard
  MicrobialStrain
}

enum InventoryActionType {
  Deduct
  Restore
}

enum InventoryTransactionType {
  CREATE
  CONSUME
  DISCARD
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  EXPIRE
  REJECT
  REVERSAL
}

enum InventoryLifecycleStatus {
  Active
  Rejected
  Expired
  Discarded
  Depleted
}

enum StockInSourceType {
  Chemical
  Standard
  MicrobialStrain
}

enum EquipmentStatus {
  InUse
  Maintenance
  Broken
  Disposed
}

enum ScheduleStatus {
  Green
  Yellow
  Red
}

enum CalibrationResult {
  Pass
  Fail
}

enum RepairProposalPriority {
  Low
  Medium
  High
  Critical
}

enum RepairProposalStatus {
  Open
  InProgress
  Completed
  Cancelled
}

enum PostCalibrationEvaluationStatus {
  Draft
  Approved
  Rejected
}

enum EquipmentDisposalStatus {
  Pending
  Approved
  Rejected
}

enum EquipmentHistoryEventType {
  Calibration
  Maintenance
  Repair
  SparePartReplacement
  Disposal
  Installation
  Manual
  Other
}

enum EquipmentHistorySourceType {
  Manual
  CalibrationRecord
  MaintenanceLog
  SparePartUsage
  EquipmentDisposal
  RepairProposal
}

model CodeSequence {
  prefix    String   @id
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

model CodeAlias {
  id         String         @id @default(cuid())
  oldCode    String
  newCode    String
  entityType CodeEntityType
  entityId   String
  migratedAt DateTime       @default(now())

  @@unique([oldCode, entityType])
  @@index([newCode])
  @@index([entityId])
}

model Chemical {
  id                String               @id @default(cuid())
  code              String               @unique
  codePrefix        String               @default("CHEM")
  sequenceNumber    Int                  @default(0)
  name              String
  chemicalGroup     String               @default("Dung môi")
  manufacturer      String               @default("")
  casNumber         String               @default("")
  productCode       String               @default("")
  lot               String               @default("")
  purity            String               @default("")
  uncertainty       String               @default("")
  coaPath           String?
  unit              String               @default("")
  quantity          Float                @default(0)
  inventoryStatus   InventoryLifecycleStatus @default(Active)
  expiryDate        DateTime?
  storageCondition  String               @default("")
  status            StandardExpiryStatus @default(Ready)
  storageLocation   String               @default("")
  notes             String               @default("")
  reorderLevel      Float                @default(5)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  containers                    Container[]
  preparedChemicalIngredients   PreparedChemicalIngredient[]
  preparedStandardSolvents      PreparedStandardSolvent[]
  stockLots                     StockLot[]
  methodReagents                MethodReagent[]

  @@index([status])
  @@index([chemicalGroup])
  @@index([expiryDate])
  @@index([codePrefix, sequenceNumber])
}

model Standard {
  id                String               @id @default(cuid())
  code              String               @unique
  codePrefix        String               @default("STD")
  sequenceNumber    Int                  @default(0)
  name              String
  standardGroup     String               @default("CRM")
  manufacturer      String               @default("")
  casNumber         String               @default("")
  productCode       String               @default("")
  lot               String               @default("")
  purity            String               @default("")
  uncertainty       String               @default("")
  coaPath           String?
  unit              String               @default("")
  quantity          Float                @default(0)
  inventoryStatus   InventoryLifecycleStatus @default(Active)
  expiryDate        DateTime?
  afterOpenExpiry   DateTime?
  storageCondition  String               @default("")
  status            StandardExpiryStatus @default(Ready)
  storageLocation   String               @default("")
  notes             String               @default("")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  containers                  Container[]
  preparedStandardComponents  PreparedStandardComponent[]
  stockLots                   StockLot[]
  methodReagents              MethodReagent[]

  @@index([status])
  @@index([standardGroup])
  @@index([expiryDate])
  @@index([codePrefix, sequenceNumber])
}

model MicrobialStrain {
  id                String               @id @default(cuid())
  code              String               @unique
  codePrefix        String               @default("STR")
  sequenceNumber    Int                  @default(0)
  name              String
  strainGroup       String               @default("Vi khuẩn")
  manufacturer      String               @default("")
  atccProductCode   String               @default("")
  lot               String               @default("")
  purity            String               @default("")
  uncertainty       String               @default("")
  coaPath           String?
  unit              String               @default("")
  quantity          Float                @default(0)
  inventoryStatus   InventoryLifecycleStatus @default(Active)
  expiryDate        DateTime?
  storageCondition  String               @default("")
  status            StandardExpiryStatus @default(Ready)
  storageLocation   String               @default("")
  passage           Int                  @default(0)
  speciesStrain     String               @default("")
  responsiblePerson String               @default("")
  notes             String               @default("")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  preparedStrains   PreparedStrain[]
  stockLots         StockLot[]

  @@index([status])
  @@index([strainGroup])
  @@index([expiryDate])
  @@index([codePrefix, sequenceNumber])
}

model StockLot {
  id                String               @id @default(cuid())
  chemicalId        String?
  standardId        String?
  microbialStrainId String?
  lot               String
  quantity          Float                @default(0)
  unit              String               @default("")
  purity            String               @default("")
  uncertainty       String               @default("")
  expiryDate        DateTime?
  afterOpenExpiry   DateTime?
  coaPath           String?
  storageLocation   String               @default("")
  notes             String               @default("")
  status            StandardExpiryStatus @default(Ready)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  chemical          Chemical?            @relation(fields: [chemicalId], references: [id], onDelete: Cascade)
  standard          Standard?            @relation(fields: [standardId], references: [id], onDelete: Cascade)
  microbialStrain   MicrobialStrain?     @relation(fields: [microbialStrainId], references: [id], onDelete: Cascade)
  stockInLogs       StockInLog[]

  @@unique([chemicalId, lot])
  @@unique([standardId, lot])
  @@unique([microbialStrainId, lot])
  @@index([chemicalId])
  @@index([standardId])
  @@index([microbialStrainId])
  @@index([expiryDate])
}

model StockInLog {
  id             String            @id @default(cuid())
  time           DateTime          @default(now())
  user           String            @default("")
  sourceType     StockInSourceType
  stockLotId     String
  sourceCode     String            @default("")
  sourceName     String            @default("")
  lot            String            @default("")
  quantityBefore Float
  quantityIn     Float
  quantityAfter  Float
  unit           String            @default("")
  notes          String            @default("")
  referenceId    String            @default("")
  stockLot       StockLot          @relation(fields: [stockLotId], references: [id], onDelete: Cascade)

  @@index([stockLotId])
  @@index([sourceType])
  @@index([time])
}

model PreparedChemical {
  id                    String                       @id @default(cuid())
  parentCode            String                       @default("")
  codePrefix            String                       @default("PCHEM")
  sequenceNumber        Int                          @default(0)
  batchNumber           Int                          @default(1)
  code                  String                       @unique
  name                  String
  concentration         String                       @default("")
  concentrationUnit     String                       @default("")
  originalConcentration String                       @default("")
  finalConcentration    String                       @default("")
  preparedQuantity      Float                        @default(0)
  unit                  String                       @default("")
  preparedDate          DateTime
  preparedBy            String                       @default("")
  preparedByStaffId     String?
  checkedByStaffId      String?
  approvedByStaffId     String?
  expiryDate            DateTime
  storageLocation       String                       @default("")
  storageCondition      String                       @default("")
  formula               String                       @default("")
  equipmentUsed         String                       @default("")
  preparationCondition  String                       @default("")
  attachmentUrl         String                       @default("")
  workflowStatus        PreparationWorkflowStatus    @default(Approved)
  inventoryStatus       InventoryLifecycleStatus     @default(Active)
  version               Int                          @default(1)
  amendmentReason       String                       @default("")
  deletedAt             DateTime?
  status                StandardExpiryStatus         @default(Ready)
  notes                 String                       @default("")
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  ingredients           PreparedChemicalIngredient[]
  preparedByStaff       Staff?                       @relation("PChemPreparedBy", fields: [preparedByStaffId], references: [id], onDelete: SetNull)
  checkedByStaff        Staff?                       @relation("PChemCheckedBy", fields: [checkedByStaffId], references: [id], onDelete: SetNull)
  approvedByStaff       Staff?                       @relation("PChemApprovedBy", fields: [approvedByStaffId], references: [id], onDelete: SetNull)
  equipmentId           String?
  equipment             Equipment?                   @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([expiryDate])
  @@index([workflowStatus])
  @@index([deletedAt])
  @@index([parentCode])
  @@index([codePrefix, sequenceNumber])
  @@index([equipmentId])
  @@unique([parentCode, batchNumber])
}

model PreparedChemicalIngredient {
  id                     String           @id @default(cuid())
  preparedChemicalId     String
  chemicalId             String
  stockLotId             String?
  chemicalNameSnapshot   String
  casProductCodeSnapshot String           @default("")
  lotNumberSnapshot      String           @default("")
  quantityUsed           Float
  unit                   String           @default("")
  consumeTransactionId   String?
  preparedChemical       PreparedChemical @relation(fields: [preparedChemicalId], references: [id], onDelete: Cascade)
  chemical               Chemical         @relation(fields: [chemicalId], references: [id])

  @@index([preparedChemicalId])
  @@index([chemicalId])
  @@index([stockLotId])
  @@index([consumeTransactionId])
}

model PreparedStandard {
  id                    String                      @id @default(cuid())
  parentCode            String                      @default("")
  codePrefix            String                      @default("PSTD")
  sequenceNumber        Int                         @default(0)
  batchNumber           Int                         @default(1)
  code                  String                      @unique
  name                  String
  level                 PreparedStandardLevel
  concentration         String                      @default("")
  concentrationUnit     String                      @default("")
  originalConcentration String                      @default("")
  finalConcentration    String                      @default("")
  solventVolume         Float                       @default(0)
  solventUnit           String                      @default("")
  preparedDate          DateTime
  preparedBy            String                      @default("")
  preparedByStaffId     String?
  checkedByStaffId      String?
  approvedByStaffId     String?
  expiryDate            DateTime
  quantity              Float                       @default(0)
  unit                  String                      @default("")
  formula               String                      @default("")
  equipmentUsed         String                      @default("")
  preparationCondition  String                      @default("")
  attachmentUrl         String                      @default("")
  workflowStatus        PreparationWorkflowStatus   @default(Approved)
  inventoryStatus       InventoryLifecycleStatus    @default(Active)
  version               Int                         @default(1)
  amendmentReason       String                      @default("")
  deletedAt             DateTime?
  status                StandardExpiryStatus        @default(Ready)
  storageLocation       String                      @default("")
  storageCondition      String                      @default("")
  notes                 String                      @default("")
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  components            PreparedStandardComponent[]
  solvents              PreparedStandardSolvent[]
  usedAsSourceIn        PreparedStandardComponent[] @relation("PreparedStandardSource")
  preparedByStaff       Staff?                      @relation("PStdPreparedBy", fields: [preparedByStaffId], references: [id], onDelete: SetNull)
  checkedByStaff        Staff?                      @relation("PStdCheckedBy", fields: [checkedByStaffId], references: [id], onDelete: SetNull)
  approvedByStaff       Staff?                      @relation("PStdApprovedBy", fields: [approvedByStaffId], references: [id], onDelete: SetNull)
  equipmentId           String?
  equipment             Equipment?                  @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  @@index([level])
  @@index([status])
  @@index([preparedDate])
  @@index([expiryDate])
  @@index([workflowStatus])
  @@index([deletedAt])
  @@index([parentCode])
  @@index([codePrefix, sequenceNumber])
  @@index([equipmentId])
  @@unique([parentCode, batchNumber])
}

model PreparedStandardComponent {
  id                       String                              @id @default(cuid())
  preparedStandardId       String
  sourceType               PreparedStandardComponentSourceType
  standardId               String?
  sourcePreparedStandardId String?
  stockLotId               String?
  standardCodeSnapshot     String                              @default("")
  standardNameSnapshot     String
  manufacturerSnapshot     String                              @default("")
  productCodeSnapshot      String                              @default("")
  lotNumberSnapshot        String                              @default("")
  puritySnapshot           String                              @default("")
  concentrationSnapshot    String                              @default("")
  concentrationUnitSnapshot String                             @default("")
  levelSnapshot            PreparedStandardLevel?
  preparedDateSnapshot     DateTime?
  expiryDateSnapshot       DateTime?
  quantityUsed             Float
  unit                     String                              @default("")
  consumeTransactionId     String?
  preparedStandard         PreparedStandard                    @relation(fields: [preparedStandardId], references: [id], onDelete: Cascade)
  standard                 Standard?                           @relation(fields: [standardId], references: [id])
  sourcePreparedStandard   PreparedStandard?                   @relation("PreparedStandardSource", fields: [sourcePreparedStandardId], references: [id])

  @@index([preparedStandardId])
  @@index([standardId])
  @@index([sourcePreparedStandardId])
  @@index([stockLotId])
  @@index([consumeTransactionId])
}

model PreparedStandardSolvent {
  id                     String           @id @default(cuid())
  preparedStandardId     String
  chemicalId             String
  stockLotId             String?
  chemicalCodeSnapshot   String           @default("")
  chemicalNameSnapshot   String
  casProductCodeSnapshot String           @default("")
  lotNumberSnapshot      String           @default("")
  quantityUsed           Float
  unit                   String           @default("")
  consumeTransactionId   String?
  preparedStandard       PreparedStandard @relation(fields: [preparedStandardId], references: [id], onDelete: Cascade)
  chemical               Chemical         @relation(fields: [chemicalId], references: [id])

  @@index([preparedStandardId])
  @@index([chemicalId])
  @@index([stockLotId])
  @@index([consumeTransactionId])
}

model PreparedStrain {
  id                      String                    @id @default(cuid())
  parentCode              String                    @default("")
  codePrefix              String                    @default("PSTR")
  sequenceNumber          Int                       @default(0)
  batchNumber             Int                       @default(1)
  level                   PreparedStrainLevel       @default(RootPrepared)
  code                    String                    @unique
  name                    String
  sourceStrainId          String
  sourceStockLotId        String?
  sourceLotNumberSnapshot String                    @default("")
  formula                 String                    @default("")
  concentration           String                    @default("")
  originalConcentration   String                    @default("")
  finalConcentration      String                    @default("")
  lot                     String                    @default("")
  preparedDate            DateTime
  preparedBy              String                    @default("")
  preparedByStaffId       String?
  checkedBy               String                    @default("")
  checkedByStaffId        String?
  approvedByStaffId       String?
  expiryDate              DateTime
  passage                 Int                       @default(0)
  storageCondition        String                    @default("")
  equipmentUsed           String                    @default("")
  preparationCondition    String                    @default("")
  attachmentUrl           String                    @default("")
  workflowStatus          PreparationWorkflowStatus @default(Approved)
  inventoryStatus         InventoryLifecycleStatus  @default(Active)
  version                 Int                       @default(1)
  amendmentReason         String                    @default("")
  deletedAt               DateTime?
  status                  InventoryItemStatus       @default(Available)
  responsiblePerson       String                    @default("")
  notes                   String                    @default("")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  sourceStrain            MicrobialStrain           @relation(fields: [sourceStrainId], references: [id])
  preparedByStaff         Staff?                    @relation("PStrPreparedBy", fields: [preparedByStaffId], references: [id], onDelete: SetNull)
  checkedByStaff          Staff?                    @relation("PStrCheckedBy", fields: [checkedByStaffId], references: [id], onDelete: SetNull)
  approvedByStaff         Staff?                    @relation("PStrApprovedBy", fields: [approvedByStaffId], references: [id], onDelete: SetNull)
  equipmentId             String?
  equipment               Equipment?                @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  @@index([sourceStrainId])
  @@index([status])
  @@index([workflowStatus])
  @@index([deletedAt])
  @@index([parentCode])
  @@index([codePrefix, sequenceNumber])
  @@index([equipmentId])
  @@unique([parentCode, batchNumber])
}

model EnvironmentalLog {
  id                  String   @id @default(cuid())
  loggedAt            DateTime
  location            String
  temperature         Float?
  humidity            Float?
  recordedByStaffId   String?
  notes               String   @default("")
  createdAt           DateTime @default(now())
  recordedByStaff     Staff?   @relation(fields: [recordedByStaffId], references: [id], onDelete: SetNull)

  @@index([loggedAt])
  @@index([recordedByStaffId])
}

model Container {
  id              String          @id @default(cuid())
  code            String          @unique
  chemicalId      String?
  standardId      String?
  lot             String
  location        String          @default("")
  quantity        Float           @default(0)
  unit            String          @default("L")
  expiryDate      DateTime
  afterOpenExpiry DateTime?
  status          ContainerStatus @default(Available)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  chemical        Chemical?       @relation(fields: [chemicalId], references: [id], onDelete: Cascade)
  standard        Standard?       @relation(fields: [standardId], references: [id], onDelete: Cascade)
  usageLogs       UsageLog[]

  @@index([chemicalId])
  @@index([standardId])
  @@index([status])
  @@index([expiryDate])
}

model Staff {
  id                         String             @id @default(cuid())
  code                       String             @unique
  name                       String
  department                 String             @default("")
  active                     Boolean            @default(true)
  usageLogs                  UsageLog[]
  user                       User?
  preparedChemicalsPrepared  PreparedChemical[] @relation("PChemPreparedBy")
  preparedChemicalsChecked   PreparedChemical[] @relation("PChemCheckedBy")
  preparedChemicalsApproved  PreparedChemical[] @relation("PChemApprovedBy")
  preparedStandardsPrepared  PreparedStandard[] @relation("PStdPreparedBy")
  preparedStandardsChecked   PreparedStandard[] @relation("PStdCheckedBy")
  preparedStandardsApproved  PreparedStandard[] @relation("PStdApprovedBy")
  preparedStrainsPrepared    PreparedStrain[]   @relation("PStrPreparedBy")
  preparedStrainsChecked     PreparedStrain[]   @relation("PStrCheckedBy")
  preparedStrainsApproved    PreparedStrain[]   @relation("PStrApprovedBy")
  environmentalLogs          EnvironmentalLog[]
}

model PreparationHistory {
  id              String           @id @default(cuid())
  preparationType PreparationType
  preparationId   String
  version         Int
  event           String
  snapshotJson    String
  reason          String           @default("")
  performedBy     String
  performedAt     DateTime         @default(now())

  @@index([preparationType, preparationId])
  @@index([performedAt])
}

model PreparationAuditLog {
  id              String           @id @default(cuid())
  preparationType PreparationType
  preparationId   String
  action          String
  beforeJson      String           @default("{}")
  afterJson       String           @default("{}")
  reason          String           @default("")
  performedBy     String
  performedAt     DateTime         @default(now())

  @@index([preparationType, preparationId])
  @@index([performedAt])
}

model UsageLog {
  id                     String          @id @default(cuid())
  date                   DateTime
  type                   UsageLogType
  sourceType             UsageSourceType
  sourceId               String
  containerId            String?
  stockLotId             String?
  inventoryTransactionId String?
  quantity               Float
  unit               String
  performedBy        String
  performedByStaffId String?
  purpose            String          @default("")
  notes              String          @default("")
  referenceCode      String          @default("")
  createdAt          DateTime        @default(now())
  container          Container?      @relation(fields: [containerId], references: [id], onDelete: SetNull)
  performedByStaff   Staff?          @relation(fields: [performedByStaffId], references: [id], onDelete: SetNull)

  @@index([sourceType, sourceId])
  @@index([containerId])
  @@index([stockLotId])
  @@index([date])
  @@index([type])
  @@index([performedBy])
}

model AuditLog {
  id         String   @id @default(cuid())
  time       DateTime @default(now())
  user       String
  action     String
  entityType String
  entityId   String
  beforeJson String   @default("{}")
  afterJson  String   @default("{}")
  object     String   @default("")

  @@index([time])
  @@index([entityType])
}

model InventoryTransaction {
  id                      String                    @id @default(cuid())
  time                    DateTime                  @default(now())
  user                    String                    @default("")
  module                  String
  sourceType              InventorySourceType
  sourceId                String
  sourceCode              String                    @default("")
  stockLotId              String?
  quantityBefore          Float
  quantityUsed            Float
  quantityAfter           Float
  unit                    String                    @default("")
  actionType              InventoryActionType
  transactionType         InventoryTransactionType?
  reason                  String                    @default("")
  relatedPreparationType  PreparationType?
  relatedPreparationId      String?
  reversesTransactionId     String?
  approvedBy              String                    @default("")
  approvedAt              DateTime?
  performedByStaffId      String?
  referenceType           String
  referenceId             String
  notes                   String                    @default("")

  @@index([sourceType, sourceId])
  @@index([stockLotId])
  @@index([referenceType, referenceId])
  @@index([transactionType])
  @@index([relatedPreparationType, relatedPreparationId])
  @@index([time])
}

model Equipment {
  id                      String                      @id @default(cuid())
  code                    String                      @unique
  name                    String
  model                   String                      @default("")
  serialNumber            String                      @default("")
  specifications          String                      @default("")
  manufacturer            String                      @default("")
  countryOfOrigin         String                      @default("")
  manufacturingYear       Int?
  purchaseDate            DateTime?
  commissioningDate       DateTime?
  lastCalibrationDate     DateTime?
  calibrator              String                      @default("")
  calibrationExpiryDate   DateTime?
  department              String                      @default("")
  location                String                      @default("")
  manager                 String                      @default("")
  status                  EquipmentStatus             @default(InUse)
  installDate             DateTime?
  iqOqPqNotes             String                      @default("")
  userManualPath          String?
  createdBy               String                      @default("")
  updatedBy               String                      @default("")
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  calibrationPlans        CalibrationPlan[]
  calibrationRecords      CalibrationRecord[]
  postCalibrationEvaluations PostCalibrationEvaluation[]
  maintenancePlans        MaintenancePlan[]
  maintenanceLogs         MaintenanceLog[]
  repairProposals         RepairProposal[]
  disposals               EquipmentDisposal[]
  historyEvents           EquipmentHistoryEvent[]
  sparePartLinks          EquipmentSparePartLink[]
  sparePartUsages         SparePartUsage[]
  preparedChemicals       PreparedChemical[]
  preparedStandards       PreparedStandard[]
  preparedStrains         PreparedStrain[]
  methodEquipmentLinks    MethodEquipment[]

  @@index([status])
  @@index([department])
  @@index([calibrationExpiryDate])
}

model CalibrationPlan {
  id          String         @id @default(cuid())
  equipmentId String
  name        String         @default("")
  cycleMonths Int            @default(12)
  lastDate    DateTime?
  nextDate    DateTime?
  vendor      String         @default("")
  status      ScheduleStatus @default(Green)
  notes       String         @default("")
  createdBy   String         @default("")
  updatedBy   String         @default("")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  equipment   Equipment      @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([nextDate])
  @@index([status])
}

model CalibrationRecord {
  id              String                      @id @default(cuid())
  equipmentId     String
  calibrationDate DateTime
  certificateNo   String                      @default("")
  result          CalibrationResult           @default(Pass)
  deviation       String                      @default("")
  calibrationResults Json                     @default("[]")
  certificatePath String?
  cost            Float                       @default(0)
  vendor          String                      @default("")
  notes           String                      @default("")
  createdBy       String                      @default("")
  updatedBy       String                      @default("")
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  equipment       Equipment                   @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  evaluation      PostCalibrationEvaluation?

  @@index([equipmentId])
  @@index([calibrationDate])
  @@index([result])
}

model PostCalibrationEvaluation {
  id                  String                          @id @default(cuid())
  equipmentId         String
  calibrationRecordId String                          @unique
  impactAssessment    String                          @default("")
  correctiveAction    String                          @default("")
  status              PostCalibrationEvaluationStatus @default(Draft)
  approvedBy          String                          @default("")
  notes               String                          @default("")
  createdBy           String                          @default("")
  updatedBy           String                          @default("")
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt
  equipment           Equipment                       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  calibrationRecord   CalibrationRecord               @relation(fields: [calibrationRecordId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([status])
}

model MaintenancePlan {
  id          String         @id @default(cuid())
  equipmentId String
  name        String         @default("")
  cycleMonths Int            @default(6)
  lastDate    DateTime?
  nextDate    DateTime?
  vendor      String         @default("")
  status      ScheduleStatus @default(Green)
  notes       String         @default("")
  createdBy   String         @default("")
  updatedBy   String         @default("")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  equipment   Equipment      @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([nextDate])
  @@index([status])
}

model MaintenanceLog {
  id               String          @id @default(cuid())
  equipmentId      String
  repairProposalId String?
  issueDate        DateTime
  description      String          @default("")
  rootCause        String          @default("")
  action           String          @default("")
  vendor           String          @default("")
  cost             Float           @default(0)
  completedDate    DateTime?
  attachmentPaths  String          @default("[]")
  notes            String          @default("")
  createdBy        String          @default("")
  updatedBy        String          @default("")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  equipment        Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  repairProposal   RepairProposal? @relation(fields: [repairProposalId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
  @@index([issueDate])
  @@index([completedDate])
}

model RepairProposal {
  id              String                 @id @default(cuid())
  equipmentId     String
  ticketNo        String                 @unique
  priority        RepairProposalPriority @default(Medium)
  status          RepairProposalStatus   @default(Open)
  description     String                 @default("")
  reportedBy      String                 @default("")
  notes           String                 @default("")
  createdBy       String                 @default("")
  updatedBy       String                 @default("")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  equipment       Equipment              @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  maintenanceLogs MaintenanceLog[]

  @@index([equipmentId])
  @@index([status])
  @@index([priority])
}

model SparePart {
  id             String                   @id @default(cuid())
  code           String                   @unique
  name           String
  manufacturer   String                   @default("")
  productCode    String                   @default("")
  lotNumber      String                   @default("")
  stockQty       Float                    @default(0)
  minQty         Float                    @default(0)
  unit           String                   @default("")
  unitPrice      Float                    @default(0)
  supplier       String                   @default("")
  notes          String                   @default("")
  createdBy      String                   @default("")
  updatedBy      String                   @default("")
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  equipmentLinks EquipmentSparePartLink[]
  usages         SparePartUsage[]

  @@index([code])
}

model EquipmentSparePartLink {
  id          String    @id @default(cuid())
  equipmentId String
  sparePartId String
  notes       String    @default("")
  createdAt   DateTime  @default(now())
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sparePart   SparePart @relation(fields: [sparePartId], references: [id], onDelete: Cascade)

  @@unique([equipmentId, sparePartId])
  @@index([equipmentId])
  @@index([sparePartId])
}

model SparePartUsage {
  id          String    @id @default(cuid())
  equipmentId String
  sparePartId String
  quantity    Float
  usedDate    DateTime
  notes       String    @default("")
  createdBy   String    @default("")
  createdAt   DateTime  @default(now())
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sparePart   SparePart @relation(fields: [sparePartId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([sparePartId])
  @@index([usedDate])
}

model EquipmentDisposal {
  id            String                  @id @default(cuid())
  equipmentId   String
  disposalDate  DateTime
  residualValue Float                   @default(0)
  decision      String                  @default("")
  approver      String                  @default("")
  documentPath  String?
  status        EquipmentDisposalStatus @default(Pending)
  notes         String                  @default("")
  createdBy     String                  @default("")
  updatedBy     String                  @default("")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  equipment     Equipment               @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([status])
}

model EquipmentHistoryEvent {
  id          String                     @id @default(cuid())
  equipmentId String
  eventType   EquipmentHistoryEventType
  eventDate   DateTime
  title       String                     @default("")
  description String                     @default("")
  sourceType  EquipmentHistorySourceType @default(Manual)
  sourceId    String?
  createdBy   String                     @default("")
  updatedBy   String                     @default("")
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  equipment   Equipment                  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId])
  @@index([equipmentId])
  @@index([eventDate])
  @@index([eventType])
}

model EquipmentAttachment {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  filePath   String
  fileName   String   @default("")
  createdBy  String   @default("")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

enum UserRole {
  Admin
  LabManager
  Analyst
  QAQC
  Viewer
}

enum UserStatus {
  Active
  Disabled
}

enum TaskStatus {
  Pending
  InProgress
  Completed
  NeedsRevision
  Cancelled
}

model User {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  passwordHash String
  avatarUrl    String           @default("")
  role         UserRole         @default(Viewer)
  status       UserStatus       @default(Active)
  staffId      String?          @unique
  staff        Staff?           @relation(fields: [staffId], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  permissions  UserPermission[]
  tasksAssigned Task[]          @relation("TaskAssignee")
  tasksCreated  Task[]          @relation("TaskAssigner")
  notificationReads NotificationRead[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String           @default("")
  users       UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String     @default("")
  assignedToId String
  assignedById String
  status       TaskStatus @default(Pending)
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignedTo   User       @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedBy   User       @relation("TaskAssigner", fields: [assignedById], references: [id], onDelete: Cascade)

  @@index([assignedToId])
  @@index([assignedById])
  @@index([status])
  @@map("tasks")
}

model Notification {
  id           String   @id @default(cuid())
  actorUserId  String?
  actorName    String
  action       String
  moduleKey    String
  moduleLabel  String
  entityType   String
  entityId     String
  recordLabel  String
  href         String
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  reads        NotificationRead[]

  @@index([createdAt])
  @@index([moduleKey])
  @@index([entityType, entityId])
  @@map("notifications")
}

model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_reads")
}

// --- Chem Info Module (reference data, separate from inventory catalog) ---

model Element {
  id                String   @id @default(cuid())
  symbol            String   @unique
  name              String
  nameVi            String   @default("")
  atomicNumber      Int      @unique
  atomicMass        Float
  group             Int?
  period            Int
  block             String   @default("")
  classification    String   @default("")
  electronConfig    String   @default("")
  electronegativity Float?
  meltingPointC     Float?
  boilingPointC     Float?
  gridRow           Int      @default(0)
  gridColumn        Int      @default(0)
  applications      String   @default("[]")
  createdAt         DateTime @default(now())

  @@index([name])
  @@index([atomicNumber])
  @@map("elements")
}

model ChemicalReference {
  id                 String   @id @default(cuid())
  casNumber          String   @unique
  name               String
  normalizedName     String   @default("")
  molecularFormula   String   @default("")
  molecularWeight    Float?
  synonyms           String   @default("[]")
  pubchemCid         Int?     @unique
  smiles             String   @default("")
  isomericSmiles     String   @default("")
  inchi              String   @default("")
  inchiKey           String   @default("")
  iupacName          String   @default("")
  structure2dUrl     String?
  notes              String   @default("")
  source             String   @default("seed")
  syncStatus         String   @default("local")
  lastSyncedAt       DateTime?
  physicalProperties String   @default("{}")
  extendedData       String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  safetyProfile      ChemicalSafetyProfile?
  sdsDocuments       SdsDocument[]
  hazardCategory     ChemicalHazardCategory?
  syncLogs           ChemicalReferenceSyncLog[]
  methodSafetyNotes  MethodSafetyNote[]

  @@index([name])
  @@index([normalizedName])
  @@index([molecularFormula])
  @@index([pubchemCid])
  @@index([inchiKey])
  @@index([syncStatus])
  @@map("chemical_references")
}

model ChemicalReferenceSyncLog {
  id                  String   @id @default(cuid())
  chemicalReferenceId String?
  chemicalReference   ChemicalReference? @relation(fields: [chemicalReferenceId], references: [id], onDelete: SetNull)
  action              String
  query               String   @default("")
  pubchemCid          Int?
  source              String   @default("PubChem")
  status              String
  message             String   @default("")
  performedBy         String   @default("")
  createdAt           DateTime @default(now())

  @@index([chemicalReferenceId])
  @@index([createdAt])
  @@map("chemical_reference_sync_logs")
}

model GhsPictogram {
  code        String @id
  label       String
  imagePath   String
  description String @default("")

  @@map("ghs_pictograms")
}

model ChemicalSafetyProfile {
  id                      String            @id @default(cuid())
  chemicalReferenceId     String            @unique
  chemicalReference       ChemicalReference @relation(fields: [chemicalReferenceId], references: [id], onDelete: Cascade)
  signalWord              String            @default("")
  hazardStatements        String            @default("[]")
  precautionaryStatements String            @default("[]")
  pictogramCodes          String            @default("[]")
  unNumber                String            @default("")
  hazardClass             String            @default("")
  packingGroup            String            @default("")
  updatedAt               DateTime          @updatedAt

  @@map("chemical_safety_profiles")
}

model SdsDocument {
  id                  String            @id @default(cuid())
  chemicalReferenceId String
  chemicalReference   ChemicalReference @relation(fields: [chemicalReferenceId], references: [id], onDelete: Cascade)
  title               String            @default("")
  supplier            String            @default("")
  revisionDate        DateTime?
  filePath            String?
  externalUrl         String?
  isPrimary           Boolean           @default(false)
  uploadedBy          String            @default("")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([chemicalReferenceId])
  @@map("sds_documents")
}

model CompatibilityRule {
  id               String  @id @default(cuid())
  code             String  @unique
  ruleType         String  @default("HAZARD")
  operandAKind     String  @default("hazard")
  operandAValue    String  @default("")
  operandBKind     String  @default("hazard")
  operandBValue    String  @default("")
  categoryA        String
  categoryB        String
  categoryALabel   String
  categoryBLabel   String
  severity         String  @default("high")
  title            String
  message          String
  storageGuidance  String  @default("")
  examples         String  @default("[]")
  isActive         Boolean @default(true)

  @@index([categoryA, categoryB])
  @@index([ruleType])
  @@index([operandAKind, operandAValue])
  @@index([operandBKind, operandBValue])
  @@map("compatibility_rules")
}

model ChemicalHazardCategory {
  id                  String            @id @default(cuid())
  chemicalReferenceId String            @unique
  chemicalReference   ChemicalReference @relation(fields: [chemicalReferenceId], references: [id], onDelete: Cascade)
  categories          String            @default("[]")

  @@map("chemical_hazard_categories")
}

model PubChemCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  payload   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("pubchem_cache")
}

// --- Analytical Methods module ---

enum MethodVersionStatus {
  Draft
  Review
  Approved
  Obsolete
}

enum WorkflowNodeType {
  Start
  Step
  Condition
  Qc
  Equipment
  Reagent
  End
}

enum WorkflowSourceType {
  Manual
  AI
  Imported
}

enum MethodExecutionStatus {
  InProgress
  Completed
  Aborted
}

enum MethodExecutionStepStatus {
  Pending
  Done
  Skipped
  Failed
}

enum MethodAIExtractionStatus {
  Pending
  Processing
  Completed
  Failed
  Superseded
}

model AnalyticalMethod {
  id               String          @id @default(cuid())
  methodCode       String          @unique
  methodName       String
  matrix           String          @default("")
  analyte          String          @default("")
  technique        String          @default("")
  standardRef      String          @default("")
  currentVersionId String?         @unique
  createdBy        String          @default("")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  currentVersion   MethodVersion?  @relation("CurrentMethodVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions         MethodVersion[] @relation("MethodVersions")

  @@index([methodCode])
  @@map("analytical_methods")
}

model MethodVersion {
  id                       String                    @id @default(cuid())
  methodId                 String
  version                  Int
  status                   MethodVersionStatus       @default(Draft)
  effectiveDate            DateTime?
  reviewDate               DateTime?
  changeLog                String                    @default("")
  createdBy                String                    @default("")
  reviewerId               String                    @default("")
  approverId               String                    @default("")
  approvedAt               DateTime?
  estimatedDurationMinutes Int?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  method                   AnalyticalMethod          @relation("MethodVersions", fields: [methodId], references: [id], onDelete: Cascade)
  currentForMethod         AnalyticalMethod?         @relation("CurrentMethodVersion")
  documents                MethodDocument[]
  workflow                 MethodWorkflow?
  reagents                 MethodReagent[]
  equipmentLinks           MethodEquipment[]
  qcRequirements           MethodQCRequirement[]
  acceptanceCriteria       MethodAcceptanceCriteria[]
  safetyNotes              MethodSafetyNote[]
  approvals                MethodApproval[]
  aiExtractionLogs         MethodAIExtractionLog[]
  executions               MethodExecution[]

  @@unique([methodId, version])
  @@index([methodId])
  @@index([status])
  @@map("method_versions")
}

model MethodDocument {
  id              String        @id @default(cuid())
  methodVersionId String
  filePath        String
  fileName        String
  fileType        String        @default("")
  fileSizeBytes   Int           @default(0)
  uploadedBy      String        @default("")
  uploadedAt      DateTime      @default(now())
  isPrimary       Boolean       @default(false)
  methodVersion   MethodVersion @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)

  @@index([methodVersionId])
  @@map("method_documents")
}

model MethodWorkflow {
  id              String           @id @default(cuid())
  methodVersionId String           @unique
  layoutJson      String           @default("{}")
  sourceType      WorkflowSourceType @default(Manual)
  isDraft         Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  methodVersion   MethodVersion    @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)
  nodes           WorkflowNode[]
  edges           WorkflowEdge[]

  @@map("method_workflows")
}

model WorkflowNode {
  id          String           @id @default(cuid())
  workflowId  String
  nodeKey     String
  type        WorkflowNodeType @default(Step)
  label       String           @default("")
  description String           @default("")
  positionX   Float            @default(0)
  positionY   Float            @default(0)
  configJson  String           @default("{}")
  workflow    MethodWorkflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, nodeKey])
  @@index([workflowId])
  @@map("workflow_nodes")
}

model WorkflowEdge {
  id            String         @id @default(cuid())
  workflowId    String
  sourceNodeKey String
  targetNodeKey String
  label         String         @default("")
  conditionJson String         @default("{}")
  workflow      MethodWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_edges")
}

model MethodReagent {
  id              String        @id @default(cuid())
  methodVersionId String
  workflowNodeKey String        @default("")
  chemicalId      String?
  standardId      String?
  nameFreeText    String        @default("")
  casNumber       String        @default("")
  amountPerSample Float         @default(0)
  unit            String        @default("")
  isConsumable    Boolean       @default(false)
  methodVersion   MethodVersion @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)
  chemical        Chemical?     @relation(fields: [chemicalId], references: [id], onDelete: SetNull)
  standard        Standard?     @relation(fields: [standardId], references: [id], onDelete: SetNull)

  @@index([methodVersionId])
  @@map("method_reagents")
}

model MethodEquipment {
  id              String        @id @default(cuid())
  methodVersionId String
  workflowNodeKey String        @default("")
  equipmentId     String
  role            String        @default("")
  methodVersion   MethodVersion @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)
  equipment       Equipment     @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([methodVersionId])
  @@index([equipmentId])
  @@map("method_equipment")
}

model MethodQCRequirement {
  id              String        @id @default(cuid())
  methodVersionId String
  qcType          String
  frequency       String        @default("")
  frequencyUnit   String        @default("")
  limitsJson      String        @default("{}")
  methodVersion   MethodVersion @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)

  @@index([methodVersionId])
  @@map("method_qc_requirements")
}

model MethodAcceptanceCriteria {
  id              String        @id @default(cuid())
  methodVersionId String
  analyte         String        @default("")
  criteriaJson    String        @default("{}")
  methodVersion   MethodVersion @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)

  @@index([methodVersionId])
  @@map("method_acceptance_criteria")
}

model MethodSafetyNote {
  id                  String             @id @default(cuid())
  methodVersionId     String
  noteType            String             @default("Warning")
  content             String             @default("")
  chemicalReferenceId String?
  methodVersion       MethodVersion      @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)
  chemicalReference   ChemicalReference? @relation(fields: [chemicalReferenceId], references: [id], onDelete: SetNull)

  @@index([methodVersionId])
  @@map("method_safety_notes")
}

model MethodApproval {
  id              String              @id @default(cuid())
  methodVersionId String
  action          String
  fromStatus      MethodVersionStatus
  toStatus        MethodVersionStatus
  performedBy     String              @default("")
  performedAt     DateTime            @default(now())
  comment         String              @default("")
  methodVersion   MethodVersion       @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)

  @@index([methodVersionId])
  @@map("method_approvals")
}

model MethodAIExtractionLog {
  id              String                   @id @default(cuid())
  methodVersionId String
  documentId      String                   @default("")
  status          MethodAIExtractionStatus @default(Pending)
  provider        String                   @default("")
  model           String                   @default("")
  promptVersion   String                   @default("")
  rawResponseJson String                   @default("{}")
  parsedJson      String                   @default("{}")
  errorMessage    String                   @default("")
  extractedAt     DateTime?
  reviewedBy      String                   @default("")
  reviewedAt      DateTime?
  createdAt       DateTime                 @default(now())
  methodVersion   MethodVersion            @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)

  @@index([methodVersionId])
  @@map("method_ai_extraction_logs")
}

model MethodExecution {
  id              String                  @id @default(cuid())
  methodVersionId String
  sampleCount     Int                     @default(1)
  status          MethodExecutionStatus   @default(InProgress)
  startedBy       String                  @default("")
  startedAt       DateTime                @default(now())
  completedAt     DateTime?
  methodVersion   MethodVersion           @relation(fields: [methodVersionId], references: [id], onDelete: Cascade)
  steps           MethodExecutionStep[]

  @@index([methodVersionId])
  @@map("method_executions")
}

model MethodExecutionStep {
  id             String                    @id @default(cuid())
  executionId    String
  stepOrder      Int                       @default(0)
  stepName       String                    @default("")
  instruction    String                    @default("")
  requiredInput  String                    @default("")
  expectedResult String                    @default("")
  operator       String                    @default("")
  timestamp      DateTime?
  status         MethodExecutionStepStatus @default(Pending)
  comment        String                    @default("")
  workflowNodeKey String                   @default("")
  execution      MethodExecution           @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("method_execution_steps")
}
